#!/usr/bin/env bash

set -Eeuo pipefail

CATALOG="${PI_PLUGIN_CATALOG:-$HOME/.config/pi/plugins.json}"
PI_DIR="${PI_CODING_AGENT_DIR:-$HOME/.pi/agent}"
SETTINGS="$PI_DIR/settings.json"

usage() {
  cat <<'EOF'
Usage:
  pi-plugin-stack install [--dry-run]
  pi-plugin-stack check
  pi-plugin-stack list

Commands:
  install  Install every pinned package, then synchronize only settings.packages.
  check    Verify the installed versions and settings.packages without changing files.
  list     Print the pinned package sources.

This command never manages models, credentials, permissions, prompts, AGENTS.md,
web access settings, MCP servers, or plugin-specific runtime configuration.
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "required command not found: $1"
}

validate_catalog() {
  [[ -f "$CATALOG" ]] || die "plugin catalog not found: $CATALOG"
  jq -e '
    def source:
      if type == "string" then . else .source end;
    .schemaVersion == 1
    and (.packages | type == "array" and length > 0)
    and all(.packages[];
      (
        type == "string"
        or (type == "object" and (.source | type == "string"))
      )
      and (
        source
        | test("^npm:(@[^/@]+/)?[^/@]+@[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?(?:\\+[0-9A-Za-z.-]+)?$")
      )
    )
  ' "$CATALOG" >/dev/null || die "invalid plugin catalog: $CATALOG"
}

package_sources() {
  jq -r '.packages[] | if type == "string" then . else .source end' "$CATALOG"
}

split_npm_source() {
  local source="$1"
  local spec="${source#npm:}"
  PACKAGE_VERSION="${spec##*@}"
  PACKAGE_NAME="${spec%@*}"
  if [[ -z "$PACKAGE_NAME" || -z "$PACKAGE_VERSION" || "$PACKAGE_NAME" == "$spec" ]] \
    || [[ ! "$PACKAGE_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+([-+][0-9A-Za-z.-]+)?$ ]]; then
    die "package source must pin an exact version: $source"
  fi
}

restore_settings_on_error() {
  local status=$?
  trap - ERR
  if [[ "${SETTINGS_EXISTED:-false}" == true ]]; then
    cp -p "$SETTINGS_BACKUP" "$SETTINGS"
  else
    rm -f "$SETTINGS"
  fi
  rm -f "${SETTINGS_BACKUP:-}"
  printf 'error: plugin installation failed; restored %s\n' "$SETTINGS" >&2
  exit "$status"
}

list_packages() {
  package_sources
}

install_packages() {
  local dry_run=false
  if [[ "${1:-}" == "--dry-run" ]]; then
    dry_run=true
    shift
  fi
  [[ $# -eq 0 ]] || die "unknown install argument: $1"

  require_command jq
  validate_catalog

  if $dry_run; then
    while IFS= read -r source; do
      printf 'would install %s\n' "$source"
    done < <(package_sources)
    printf 'would synchronize only %s -> packages\n' "$SETTINGS"
    return
  fi

  require_command pi
  mkdir -p "$PI_DIR"
  jq empty "$SETTINGS" 2>/dev/null || {
    [[ ! -e "$SETTINGS" ]] || die "invalid Pi settings: $SETTINGS"
  }

  SETTINGS_BACKUP="$(mktemp "${TMPDIR:-/tmp}/pi-settings-backup.XXXXXX")"
  SETTINGS_EXISTED=false
  if [[ -f "$SETTINGS" ]]; then
    SETTINGS_EXISTED=true
    cp -p "$SETTINGS" "$SETTINGS_BACKUP"
  fi
  trap restore_settings_on_error ERR

  while IFS= read -r source; do
    printf 'Installing %s\n' "$source"
    pi install "$source"
  done < <(package_sources)

  if [[ ! -f "$SETTINGS" ]]; then
    printf '{}\n' >"$SETTINGS"
  fi
  jq empty "$SETTINGS"

  local candidate
  candidate="$(mktemp "$PI_DIR/settings.json.plugins.XXXXXX")"
  trap 'rm -f "$candidate"' EXIT
  jq --slurpfile catalog "$CATALOG" \
    '.packages = $catalog[0].packages' \
    "$SETTINGS" >"$candidate"
  mv "$candidate" "$SETTINGS"
  trap - EXIT
  trap - ERR
  rm -f "$SETTINGS_BACKUP"

  printf 'Plugin stack installed; synchronized only settings.packages.\n'
}

check_packages() {
  require_command jq
  validate_catalog
  [[ -f "$SETTINGS" ]] || die "Pi settings not found: $SETTINGS"
  jq empty "$SETTINGS"

  jq -s -e '.[0].packages == .[1].packages' \
    "$SETTINGS" "$CATALOG" >/dev/null \
    || die "settings.packages differs from plugins.json"

  local source
  while IFS= read -r source; do
    split_npm_source "$source"
    local manifest="$PI_DIR/npm/node_modules/$PACKAGE_NAME/package.json"
    [[ -f "$manifest" ]] || die "package is not installed: $PACKAGE_NAME"
    local installed
    installed="$(jq -r '.version' "$manifest")"
    [[ "$installed" == "$PACKAGE_VERSION" ]] \
      || die "$PACKAGE_NAME: expected $PACKAGE_VERSION, found $installed"
    printf 'ok  %s@%s\n' "$PACKAGE_NAME" "$installed"
  done < <(package_sources)

  local resource
  while IFS=$'\t' read -r source resource; do
    split_npm_source "$source"
    local resource_path="$PI_DIR/npm/node_modules/$PACKAGE_NAME/$resource"
    [[ -e "$resource_path" ]] \
      || die "$PACKAGE_NAME: configured resource is missing: $resource"
  done < <(
    jq -r '
      .packages[]
      | select(type == "object")
      | .source as $source
      | ((.extensions // []) + (.skills // []))[]
      | [$source, .]
      | @tsv
    ' "$CATALOG"
  )

  printf 'Plugin stack is synchronized.\n'
}

main() {
  local command="${1:-help}"
  shift || true
  case "$command" in
    install) install_packages "$@" ;;
    check)
      [[ $# -eq 0 ]] || die "check takes no arguments"
      check_packages
      ;;
    list)
      [[ $# -eq 0 ]] || die "list takes no arguments"
      require_command jq
      validate_catalog
      list_packages
      ;;
    help | --help | -h)
      usage
      ;;
    *)
      usage >&2
      die "unknown command: $command"
      ;;
  esac
}

main "$@"
