# macOS
.DS_Store

# Logs and caches
.nvimlog
nvim.log
__pycache__/

# Build artifacts
target/
dist/
public/

# Fish runtime/plugin outputs. Fisher is generated from the tracked plugin list;
# other functions and conf.d files should remain visible to Git by default.
config/fish/fish_variables
config/fish/completions/
config/fish/functions/fisher.fish
config/fish/themes/

# Machine/platform-specific Ghostty overrides.
config/ghostty/config.local

# Herdr runtime files (sockets, logs, session state). Keep config.toml tracked.
config/herdr/*.sock
config/herdr/*.log
config/herdr/session.json
config/herdr/release-notes.json

# Superpowers working documents
docs/superpowers/
.superpowers/

# AI / Claude Code local configuration
.claude/
