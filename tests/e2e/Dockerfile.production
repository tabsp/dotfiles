# Dockerfile for dotman production manual E2E test.
# Uses REAL production config (dotman.yaml, config/, bin/)
# from the repo root — no fixture duplication.
#
# Unlike the CI Dockerfile, this creates a user WITH password-required sudo,
# so sudo genuinely requires a password — enabling real TTY password testing.
# Unlike Dockerfile.sudo, this does NOT preinstall tools that the production
# config would install (fish, tmux, neovim, etc.), so the deploy flow is
# exercised end-to-end.
FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# Minimum base dependencies only — do NOT preinstall tools that production
# dotman.yaml would install (fish, tmux, neovim, ripgrep, etc.).
# hadolint ignore=DL3008
RUN apt-get update -qq && apt-get install -y -qq --no-install-recommends \
    bash git curl ca-certificates sudo build-essential rsync \
    python3 python3-yaml unzip \
    && rm -rf /var/lib/apt/lists/*

SHELL ["/bin/bash", "-o", "pipefail", "-c"]
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain stable
ENV PATH="/root/.cargo/bin:$PATH"

# Create non-root user with password-required sudo.
# Password is set to "dotman" for reproducibility.
RUN useradd -m -s /bin/bash dotman-test \
    && echo 'dotman-test:dotman' | chpasswd \
    && echo 'dotman-test ALL=(ALL) ALL' > /etc/sudoers.d/dotman-test

WORKDIR /app
COPY . .
RUN cargo build --release \
    && chown -R dotman-test:dotman-test /app/target \
    && chmod +x /app/tests/e2e/*.sh /app/tests/e2e/scenarios/*.sh

USER dotman-test
ENV HOME=/home/dotman-test
ENV DOTMAN_BIN=/app/target/release/dotman
ENTRYPOINT ["bash"]
