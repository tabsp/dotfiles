    "git diff --staged": "allow",
    "git log *": "allow",
    "git show *": "allow",
    "git grep *": "allow",
    "git ls-files *": "allow",
    "git branch --show-current": "allow",
    "git rev-parse --show-toplevel": "allow",
    "cargo check *": "allow",
    "cargo test *": "allow",
    "cargo clippy *": "allow",
    "cargo fmt --check *": "allow",
    "make test": "allow",
    "make lint": "allow",
    "make format-check": "allow",
    "make config-check": "allow",
