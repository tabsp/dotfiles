    "npm run lint *": "allow",
    "npm run typecheck *": "allow",
    "pnpm test *": "allow",
    "pnpm lint *": "allow",
    "pnpm typecheck *": "allow",
    "yarn test *": "allow",
    "yarn lint *": "allow",
    "go test *": "allow",
    "go vet *": "allow",
    "pytest *": "allow",
    "ruff check *": "allow",
    "sed *-i*": "ask",
    "sed *--in-place*": "ask",
    "yq *-i*": "ask",
    "yq *--inplace*": "ask",
    "rg *--pre*": "ask",
    "git *--output*": "ask",
    "*;*": "ask",
    "*\n*": "ask",
    "*\r\n*": "ask",
    "*&*": "ask",
    "*&&*": "ask",
    "*||*": "ask",
    "*|*": "ask",
    "*$(*": "ask",
    "*`*": "ask",
