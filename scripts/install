#!/usr/bin/env sh
# dotman installer (v2 minimal).
# Detects platform, downloads pre-built binary, exits.
# Bootstrap (brew, sudo, /etc/shells) is handled by `dotman` itself.
set -eu

base_url=${DOTFILES_SITE_URL:-"https://github.com/tabsp/dotfiles/releases/latest/download"}
bin_path=${DOTMAN_BIN:-"$HOME/.local/bin/dotman"}
tmp_dir=$(mktemp -d)
trap 'rm -rf "$tmp_dir"' EXIT

usage() {
  cat <<EOF
Usage: install [options]

Options:
  --bin-path DIR   Install dotman binary to DIR (default: ~/.local/bin/dotman)
  --version VER    Install a specific version (default: latest)
  -h, --help       Show this help
EOF
}

bin_dir=$(dirname "$bin_path")
version="latest"
while [ "$#" -gt 0 ]; do
  case "$1" in
    --bin-path) bin_path="$2"; shift 2 ;;
    --version) version="$2"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) echo "error: unknown option: $1" >&2; usage >&2; exit 2 ;;
  esac
done

detect_target() {
  os=$(uname -s)
  arch=$(uname -m)
  case "$os:$arch" in
    Darwin:arm64)   printf 'aarch64-apple-darwin' ;;
    Darwin:x86_64)  printf 'x86_64-apple-darwin' ;;
    Linux:x86_64)   printf 'x86_64-unknown-linux-gnu' ;;
    Linux:aarch64|Linux:arm64) printf 'aarch64-unknown-linux-gnu' ;;
    *) echo "error: unsupported platform: $os $arch" >&2; exit 1 ;;
  esac
}

target=$(detect_target)
[ "$version" = "latest" ] && version="latest" || version="tags/v$version"

archive="$tmp_dir/dotman-$target.tar.gz"
asset_name="dotman-$target.tar.gz"
download_url="$base_url/$asset_name"

if command -v curl >/dev/null 2>&1; then
  curl -fsSL "$download_url" -o "$archive" || { echo "error: download failed" >&2; exit 1; }
else
  echo "error: curl required" >&2; exit 1
fi

mkdir -p "$bin_dir"
tar -xzf "$archive" -C "$tmp_dir"
install -m 755 "$tmp_dir/dotman" "$bin_path"

echo "dotman installed to $bin_path"
echo "Run: $bin_path"
